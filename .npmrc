# The Nuxt ecosystem resolves several packages by convention (npm's flat
# node_modules) rather than declaring them — e.g. @nuxt/image loads `sharp`
# as an optional peer. pnpm's strict, symlinked layout hides those, which
# surfaces as build warnings (sharp) or runtime failures. Hoisting restores the
# flat resolution these tools assume. This does NOT cost disk: pnpm still hard-
# links every package from the global content-addressable store — hoisting only
# changes how node_modules is laid out, not how many bytes it uses.
shamefully-hoist=true
