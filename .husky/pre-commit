#!/usr/bin/env sh

# Skip all checks if only markdown files are staged
staged_files=$(git diff --cached --name-only)
non_md_files=$(echo "$staged_files" | grep -v '\.md$' | grep -v '^$' || true)

if [ -z "$non_md_files" ]; then
  echo "Only markdown files staged, skipping pre-commit checks."
  exit 0
fi

# Keep the local hook fast. CI runs the full-repo lint/typecheck/test suite.
pnpm exec lint-staged
