    "@types/webpack-env": "^1.18.8",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/test-utils": "^2.4.11",
    "accented": "^1.3.2",
