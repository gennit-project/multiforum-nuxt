{
  "name": "multiforum",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host 127.0.0.1 --port 3000",
    "dev:mocked": "VITE_E2E_MOCK_MODE=true nuxt dev --host 127.0.0.1 --port 3000",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "compile": "graphql-codegen",
    "lint": "eslint",
    "lint:a11y": "npx eslint \"components/**/*.vue\" --quiet",
    "prepare": "husky install",
    "prettier:check": "prettier --check .",
    "start": "nuxt start",
    "test:playwright": "playwright test tests/playwright/mocked",
    "test:playwright:mocked": "playwright test tests/playwright/mocked",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "coverage": "vitest run --coverage",
    "coverage:ui": "vitest --coverage --ui",
    "coverage:open": "npm run coverage && open coverage/index.html",
    "knip": "knip",
    "tsc": "vue-tsc --noEmit",
    "verify": "npm run tsc && npm run test:unit:run",
    "lint-verify": "npm run test:unit:run && npm run lint:a11y"
  },
  "dependencies": {
    "@apollo/client": "^3.13.5",
    "@auth0/auth0-vue": "^2.7.0",
