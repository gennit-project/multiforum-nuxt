    "@nuxt/image": "^1.10.0",
    "@nuxt/schema": "^4.4.8",
    "@nuxt/types": "^2.18.1",
    "@nuxtjs/apollo": "^5.0.0-alpha.15",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/tailwindcss": "^6.13.2",
    "@pinia/testing": "^1.0.1",
    "@playwright/test": "^1.60.0",
    "@types/crypto-js": "^4.2.2",
    "@types/diff-match-patch": "^1.0.36",
