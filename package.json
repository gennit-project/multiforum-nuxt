    "eslint": "^9.39.4",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "globals": "^15.15.0",
    "happy-dom": "^18.0.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "sass": "^1.101.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6",
    "vue-tsc": "^2.2.8"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ],
    "*.vue": [
      "eslint --fix"
    ]
  }
}
