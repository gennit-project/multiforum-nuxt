    "dotenv": "^17.4.2",
    "graphql": "^16.14.2",
    "graphql-tag": "^2.12.6",
    "highlight.js": "^11.11.1",
    "identicon.js": "^2.3.3",
    "isomorphic-dompurify": "^3.3.0",
    "js-yaml": "^4.2.0",
    "jwt-decode": "^4.0.0",
    "lightgallery": "^2.8.3",
    "lucide-vue-next": "^0.548.0",
    "luxon": "^3.6.0",
    "markdown-it": "^14.2.0",
    "md-editor-v3": "^6.5.1",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.2",
    "three": "^0.183.2",
    "tslib": "^2.8.1",
    "v-code-diff": "^1.13.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "^3.5.38",
    "vue-chartjs": "^5.3.2",
    "vue-codemirror": "^6.1.1",
    "vue-easy-lightbox": "^1.19.0",
    "vue-google-maps-community-fork": "^0.3.1",
    "vue-router": "^4.5.0",
    "vue3-popper": "^1.5.0",
